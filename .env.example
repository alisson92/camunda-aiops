# .env.example — template de variáveis de ambiente
#
# Copie este arquivo para agent/.env e preencha os valores reais.
# NUNCA commite agent/.env — ele está no .gitignore.
#
# Twelve-Factor App (Factor III): https://12factor.net/config

# ── Ollama (LLM local) ─────────────────────────────────────────────────────────
# URL base da API compatível com OpenAI exposta pelo Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# Modelo a usar — deve estar disponível localmente (ollama pull <model>)
OLLAMA_MODEL=qwen2.5:7b

# ── Prometheus ─────────────────────────────────────────────────────────────────
# URL do Prometheus acessível via port-forward:
#   kubectl port-forward -n monitoring svc/kube-prometheus-stack-prometheus 9090:9090
PROMETHEUS_URL=http://localhost:9090

# ── Alertmanager ───────────────────────────────────────────────────────────────
# URL do Alertmanager acessível via port-forward:
#   kubectl port-forward -n monitoring svc/kube-prometheus-stack-alertmanager 9093:9093
ALERTMANAGER_URL=http://localhost:9093

# ── Microsoft Teams ────────────────────────────────────────────────────────────
# URL do Incoming Webhook do canal Teams.
# Obter em: canal → ... → Gerenciar canal → Conectores → Incoming Webhook
TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/...

# ── Grafana ────────────────────────────────────────────────────────────────────
# URL base do Grafana (sem barra final)
GRAFANA_URL=http://localhost:3000

# UID do dashboard principal (visível na URL ao abrir o dashboard)
GRAFANA_DASHBOARD_UID=camunda-local-forecasting

# ── Agente ─────────────────────────────────────────────────────────────────────
# URL pública do agente — usada para montar o link do botão "Silence" no card Teams.
# Em produção: substituir por URL externa (Load Balancer, Ingress, ngrok, etc.)
AGENT_PUBLIC_URL=http://localhost:5001

# ── Logging ────────────────────────────────────────────────────────────────────
# Nível de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
